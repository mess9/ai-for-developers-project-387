# По умолчанию e2e целится в изолированный e2e-стек (compose.e2e.yaml): порты 8082/5433.
# Дев-стек (compose.yaml, 8081/5432) для ручных проверок остаётся нетронутым.
E2E_BASE_URL=http://localhost:8082

# Подключение к БД e2e-стека (тесты сеют данные напрямую и делают TRUNCATE).
PGHOST=localhost
PGPORT=5433
PGDATABASE=booking
PGUSER=booking
PGPASSWORD=booking

# Управление жизненным циклом e2e-стека из прогона:
#   1/true  — globalSetup поднимет стек, globalTeardown погасит;
#   0/false — стек поднимаете сами;
#   не задано — авто: в CI включено, локально выключено.
# E2E_MANAGE_STACK=1
